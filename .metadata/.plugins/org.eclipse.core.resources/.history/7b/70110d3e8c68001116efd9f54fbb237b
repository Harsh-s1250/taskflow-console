package com.taskflow.main;

import java.sql.Connection;
import java.time.LocalDate;
import java.util.List;
import java.util.Scanner;

import com.taskflow.dao.ProjectDAO;
import com.taskflow.dao.TaskDAO;
import com.taskflow.dao.UserDAO;
import com.taskflow.dao.impl.ProjectDAOImpl;
import com.taskflow.dao.impl.TaskDAOImpl;
import com.taskflow.dao.impl.UserDAOImpl;
import com.taskflow.model.Priority;
import com.taskflow.model.Project;
import com.taskflow.model.Status;
import com.taskflow.model.Task;
import com.taskflow.model.User;
import com.taskflow.util.DBConnection;

public class Main {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Connection con = DBConnection.getConnection();
		if(con!=null) {
			System.out.println("Success");
		}else {
			System.out.println("Fail");
		}
		
		Scanner sc = new Scanner(System.in);
		UserDAO userDAO = new UserDAOImpl();
		ProjectDAO projectDAO = new ProjectDAOImpl();
		TaskDAO taskDAO = new TaskDAOImpl();
		User currUser = null;
		
		while(true) {
			System.out.println("\n==== TASKFLOW ====");
			System.out.println("1. Register");
			System.out.println("2. Login");
			System.out.println("3. Exit");
			
			System.out.println("Enter your Choice: ");
			int choice = sc.nextInt();
			sc.nextLine();
			
			if(choice == 1) {
				System.out.println("\n==== REGISTER ====");
				System.out.println("Enter Username: ");
				String username = sc.nextLine();
				System.out.println("Enter Email: ");
				String email = sc.nextLine();
				System.out.println("Enter Password: ");
				String password = sc.nextLine();
				
				User user = new User(username, email, password);
				boolean success = userDAO.register(user);
				if(success) {
					System.out.println("success");
				}else {
					System.out.println("fail");
				}
			}else if(choice==2) {
				System.out.println("\n==== LOGIN ====");
				System.out.println("Enter Email: ");
				String email = sc.nextLine();
				System.out.println("Enter Password: ");
				String password = sc.nextLine();
				
				currUser = userDAO.login(email,password);
				if(currUser!=null) {
					System.out.println("Welcome "+currUser.getUsername());
					
					while(currUser != null) {

					    System.out.println("\n===== DASHBOARD =====");
					    System.out.println("Welcome " +currUser.getUsername());

					    System.out.println("1. Projects");
					    System.out.println("2. Tasks");
					    System.out.println("3. View Statistics");
					    System.out.println("4. Logout");

					    System.out.print("Enter choice: ");

					    int dashboardChoice = sc.nextInt();
					    sc.nextLine();
					    
					    if (dashboardChoice == 1) {

					        System.out.println("\n=== PROJECTS ===");
					        System.out.println("1. Create Project");
					        System.out.println("2. View Projects");

					        System.out.print("Enter choice: ");

					        int projectChoice = sc.nextInt();
					        sc.nextLine();
					        
					        if (projectChoice == 1) {
					        	System.out.print("Enter Project Name: ");
					        	String name = sc.nextLine();

					        	System.out.print("Enter Description: ");
					        	String description = sc.nextLine();
					        	
					        	Project project = new Project(name, description, currUser.getUserId());
					        	
					        	boolean success = projectDAO.createProject(project);

					            if (success) {
					                System.out.println("Project Created Successfully.");
					            } else {
					                System.out.println("Failed to Create Project.");
					            }
					        }else if (projectChoice == 2) {
					        	List<Project> projects = projectDAO.getProjectsByOwner(currUser.getUserId());
					        	if(projects.isEmpty()) {
					        		System.out.println("No projects found!");
					        	}else {
					        		for(Project p: projects) {
					        			System.out.println("\n------------------");
					        			System.out.println("Project ID: "+p.getProjectId());
					        			System.out.println("Name: "+p.getName());
					        			System.out.println("Description: "+p.getDescription());
					        		}
					        	}
					        }

					    }else if(dashboardChoice == 2) {
					    	System.out.println("\n=== PROJECTS ===");
					        System.out.println("1. Create Task");
					        System.out.println("2. View Tasks");
					        System.out.println("3. Update Status");

					        System.out.print("Enter choice: ");

					        int taskChoice = sc.nextInt();
					        sc.nextLine();
					        
					        if(taskChoice==1) {
					        	System.out.print("Title: ");
					        	String title = sc.nextLine();

					        	System.out.print("Description: ");
					        	String description = sc.nextLine();
					        	
					        	System.out.print("Project ID: ");
					        	int projectId = sc.nextInt();
					        	sc.nextLine();
					        	
					        	System.out.println("Due Date (YYYY-MM-DD): ");
					        	LocalDate dueDate = LocalDate.parse(sc.nextLine()); 
					        	
					        	int assignedTo = currUser.getUserId();
					        	System.out.println("Select Status:");
					        	System.out.println("1. TODO");
					        	System.out.println("2. IN_PROGRESS");
					        	System.out.println("3. DONE");
					        	
					        	int statusChoice = sc.nextInt();
					        	sc.nextLine();
					        	
					        	Status status;

					        	switch (statusChoice) {

					        	    case 1:
					        	        status = Status.TODO;
					        	        break;

					        	    case 2:
					        	        status = Status.IN_PROGRESS;
					        	        break;

					        	    case 3:
					        	        status = Status.DONE;
					        	        break;
					        	        
					        	    case 4:
						        	    status = Status.BLOCKED;
						        	    break;
					        	    default:
					        	        System.out.println("Invalid Status.");
					        	        continue;
					        	}
					        	
					        	System.out.println("Select Priority:");
					        	System.out.println("1. LOW");
					        	System.out.println("2. MEDIUM");
					        	System.out.println("3. HIGH");

					        	int priorityChoice = sc.nextInt();
					        	sc.nextLine();
					        	
					        	Priority priority;

					        	switch (priorityChoice) {

					        	    case 1:
					        	        priority = Priority.LOW;
					        	        break;

					        	    case 2:
					        	        priority = Priority.MEDIUM;
					        	        break;

					        	    case 3:
					        	        priority = Priority.HIGH;
					        	        break;

					        	    default:
					        	        System.out.println("Invalid Priority.");
					        	        continue;
					        	}
					        	Task task = new Task(
					        	        title,
					        	        description,
					        	        status,
					        	        priority,
					        	        dueDate,
					        	        assignedTo,
					        	        projectId
					        	);

					        	boolean success = taskDAO.createTask(task);
					        	
					        	if (success) {
					                System.out.println("Task Assigned Successfully.");
					            } else {
					                System.out.println("Failed to Assign Task.");
					            }
					        }else if(taskChoice==2) {
					        	System.out.print("Enter Project ID: ");
					        	int projectId = sc.nextInt();
					        	sc.nextLine();

					        	List<Project> projects = projectDAO.getProjectsByOwner(currUser.getUserId());
					        	boolean isOwner = false;
					        	for (Project p : projects) {
					        	    if (p.getProjectId() == projectId) {
					        	        isOwner = true;
					        	        break;
					        	    }
					        	}
					        	if (!isOwner) {
					        	    System.out.println("You don't have access to this project.");
					        	    continue;
					        	}
					        	List<Task> tasks = taskDAO.getTasksByProject(projectId);
					        	if (tasks.isEmpty()) {
					        	    System.out.println("No Tasks Found.");
					        	} else {
					        	    for (Task t : tasks) {

					        	        System.out.println("\n----------------");

					        	        System.out.println("Task ID: "+ t.getTaskId());
					        	        System.out.println("Title: "+ t.getTitle());
					        	        System.out.println("Description: "+ t.getDescription());
					        	        System.out.println("Status: "+ t.getStatus());
					        	        System.out.println("Priority: "+ t.getPriority());
					        	        System.out.println("Due Date: "+ t.getDueDate());
					        	    }
					        	}
					        }else if(taskChoice==3) {
					        	
					        	System.out.print("Enter Task ID: ");
					        	int taskId = sc.nextInt();
					        	sc.nextLine();
					        	
					        	System.out.print("Enter Project ID: ");
					        	int projectId = sc.nextInt();
					        	sc.nextLine();

					        	List<Project> projects = projectDAO.getProjectsByOwner(currUser.getUserId());
					        	boolean isOwner = false;
					        	for (Project p : projects) {
					        	    if (p.getProjectId() == projectId) {
					        	        isOwner = true;
					        	        break;
					        	    }
					        	}
					        	if (!isOwner) {
					        	    System.out.println("You don't have access to this project.");
					        	    continue;
					        	}
					        	
					        	System.out.println("Select New Status:");
					        	System.out.println("1. TODO");
					        	System.out.println("2. IN_PROGRESS");
					        	System.out.println("3. DONE");

					        	int statusChoice = sc.nextInt();
					        	sc.nextLine();
					        	Status status;

					        	switch (statusChoice) {
					        	    case 1:
					        	        status = Status.TODO;
					        	        break;
					        	    case 2:
					        	        status = Status.IN_PROGRESS;
					        	        break;
					        	    case 3:
					        	        status = Status.DONE;
					        	        break;
					        	    case 4:
					        	        status = Status.BLOCKED;
					        	        break;
					        	    default:
					        	        System.out.println("Invalid Status.");
					        	        continue;
					        	}
					        	boolean success = taskDAO.updateTaskStatus(taskId, status);

					            if (success) {
					                System.out.println("Task Status Updated Successfully.");
					            } else {
					                System.out.println("Failed to Update Task Status.");
					            }
					        }
					    }else if(dashboardChoice == 3) {
					    	int totalProjects = projectDAO.getProjectCountByOwner(currUser.getUserId());

					    	int totalTasks = taskDAO.getTotalTasksByUser(currUser.getUserId());

					    	int todoCount = taskDAO.countTasksByStatus(currUser.getUserId(),Status.TODO);

					    	int inProgressCount = taskDAO.countTasksByStatus(currUser.getUserId(),Status.IN_PROGRESS);

					    	int doneCount = taskDAO.countTasksByStatus(currUser.getUserId(),Status.DONE);
					    	
					    	System.out.println("\n===== STATISTICS =====");

					    	System.out.println("Total Projects: "+ totalProjects);

					    	System.out.println("Total Tasks: "+ totalTasks);

					    	System.out.println("TODO Tasks: "+ todoCount);

					    	System.out.println("IN_PROGRESS Tasks: "+ inProgressCount);

					    	System.out.println("DONE Tasks: "+ doneCount);
					    	
					    }else if(dashboardChoice == 4) {
					        currUser = null;
					        System.out.println("Logged Out Successfully.");
					    }else {
					    	System.out.println("Invalid choice try again");
					    }
					}
				}else {
					System.out.println("Invalid credentials");
				}
			}else if(choice==3){
				System.out.println("Exiting...");
				break;
			}else {
				System.out.println("Invalid choice try again");
			}
		}
//		User user = new User(1, "Harshad", "harshad@gmail.com","12334");
		
		
	}

}
